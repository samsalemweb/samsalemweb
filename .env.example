# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered (required on Vercel)
CONTACT_TO_EMAIL=

# Optional: after you verify a domain in Resend, set a custom From address.
# Until then, the API uses onboarding@resend.dev (no domain verification required).
# If RESEND_FROM_EMAIL uses an unverified domain, sends fail with HTTP 502.
# RESEND_FROM_EMAIL="Sam Salem <notifications@yourdomain.com>"

# Vercel: add all variables in Project Settings → Environment Variables, then redeploy
# (Production) so serverless functions pick up new values. With onboarding@resend.dev,
# CONTACT_TO_EMAIL must be the email on your Resend account unless you verify a domain.
