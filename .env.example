# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# Where form submissions are delivered (Contact, FAQ, Assignment forms)
# Must be set on Vercel Production as well as in .env.local
CONTACT_TO_EMAIL=salemhomes@yahoo.com

# Optional: after you verify a domain in Resend, set a custom From address.
# Until then, the API uses onboarding@resend.dev (no domain verification required).
# If RESEND_FROM_EMAIL uses an unverified domain, sends fail with HTTP 502.
# RESEND_FROM_EMAIL="Sam Salem <notifications@yourdomain.com>"

# --- Vercel (required for production forms) ---
# Project Settings → Environment Variables → add BOTH:
#   RESEND_API_KEY=<your key>
#   CONTACT_TO_EMAIL=salemhomes@yahoo.com
# Enable for Production, then Redeploy.
# With onboarding@resend.dev, CONTACT_TO_EMAIL must match your Resend account email
# unless you have verified a sending domain.
